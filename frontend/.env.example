# Copy this file to .env.local (which is gitignored) and fill in real values.
# Vite exposes only VITE_* vars to the browser; the unprefixed ones are
# auto-aliased server-side by vite.config.ts loadServerEnv().

# ─── Supabase (REQUIRED) ─────────────────────────────────────────────────
# Find these in Supabase Studio → Project Settings → API.
# Use the *anon* key in production + Row-Level Security. The demo currently
# uses the service_role key for convenience; ROTATE before going public.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=ey...

# ─── Anthropic (REQUIRED for Copilot + Evidence Report) ──────────────────
# Server-only — never exposed to the browser. Used by /api/copilot and
# /api/evidence-report Vite middleware proxies in vite.config.ts.
ANTHROPIC_API_KEY=sk-ant-api03-...

# ─── AWS Bedrock (OPTIONAL — replaces Anthropic when both are set) ───────
# AWS_BEDROCK_REGION=us-east-1
# AWS_BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-5-20250929-v2:0

# ─── Python evidence-report runner (OPTIONAL) ────────────────────────────
# Path to the backend repo. Defaults to ../backend if you keep the
# monorepo layout. The vite.config evidence-report proxy spawns a Python
# subprocess from this path.
BACKEND_REPO_PATH=../backend

# ─── Python executable (OPTIONAL) ───────────────────────────────────────
# Defaults to "python" on PATH. Set this to an absolute path if you
# manage multiple Python versions.
# PYTHON_EXECUTABLE=python

# ─── VLSFO spot price (OPTIONAL — used for financial-impact calc) ───────
# VLSFO_SPOT_PRICE=585
