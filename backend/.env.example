# Copy this file to .env (gitignored) and fill in real values.

# ─── Supabase ────────────────────────────────────────────────────────────
# Same project as the frontend. Use the service_role key for the backend
# since it writes evidence_reports and reads MFM streams across sessions.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=ey...

# ─── LLM provider ───────────────────────────────────────────────────────
LLM_PROVIDER=bedrock
AWS_REGION=us-west-2
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-20250514-v1:0
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# ─── Enrichment and object storage ─────────────────────────────────────
EXA_API_KEY=
S3_BUCKET=bunkerguard-ai-evidence-example
CORS_ORIGIN=http://localhost:5173

# ─── Ingestion defaults (Stage 1, optional) ──────────────────────────────
BDN_DEFAULT_PORT=Singapore
BDN_SESSION_PREFIX=SES

# ─── Spot pricing (used in financial-impact estimates) ───────────────────
VLSFO_SPOT_PRICE=585
